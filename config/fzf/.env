# fzf environment. Sourced early in shell init.
#
# Per-invocation previews live in .aliases / .functions — not here — because
# the default OPTS apply to every fzf call (file pickers, dir pickers, raw
# text, history, completion) and no single preview command works for all.

# Detect fd binary (Debian/Ubuntu ships it as `fdfind`).
if command -v fd >/dev/null 2>&1; then
    _FD=fd
elif command -v fdfind >/dev/null 2>&1; then
    _FD=fdfind
else
    echo "Warning: neither 'fd' nor 'fdfind' is installed; fzf listing will fall back to find." >&2
    _FD=
fi

if [ -n "$_FD" ]; then
    export FZF_DEFAULT_COMMAND="$_FD --type f --hidden --follow --exclude .git"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="$_FD --type d --hidden --follow --exclude .git"
fi
unset _FD

# Global UI: layout + keybindings. No --preview here on purpose.
export FZF_DEFAULT_OPTS='
    --height=60%
    --layout=reverse
    --border
    --info=inline
    --bind=ctrl-/:toggle-preview
    --bind=ctrl-d:half-page-down
    --bind=ctrl-u:half-page-up
    --bind=shift-up:preview-page-up
    --bind=shift-down:preview-page-down
'
