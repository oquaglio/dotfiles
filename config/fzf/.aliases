# Reconcile fd / fdfind across distros (Debian renamed `fd` to `fdfind`
# to avoid conflict with another tool).
if command -v fdfind >/dev/null 2>&1 && ! command -v fd >/dev/null 2>&1; then
    alias fd='fdfind'
fi
if command -v fd >/dev/null 2>&1 && ! command -v fdfind >/dev/null 2>&1; then
    alias fdfind='fd'
fi

# fz — fuzzy-pick a file with bat preview; prints the path to stdout.
# Compose with anything: `vim "$(fz)"`, `cat $(fz)`, `cp "$(fz)" backup/`.
alias fz='fzf --preview "bat --style=numbers --color=always --line-range :500 {} 2>/dev/null || cat {}"'

# f — fuzzy cd. Implemented as a function (fzcd) in .functions.
alias f='fzcd'
