# Fzf-powered selectors. All print useful state to stdout on cancel.
#
#   fzcd            cd into a fuzzy-picked directory (alias: f)
#   fzrg <term>     ripgrep → fzf → $EDITOR at line (alias: fr)
#   fkill [signal]  pick processes (multi-select), send signal (default 9)
#   fbr             checkout a branch (preview: git log of that branch)
#   gco             checkout any ref (branch / tag), one combined picker
#   fadd            git-add files with multi-select, preview diff
#   dexec [cmd]     docker exec -it into a running container (default: sh)
#   dlog            docker logs -f on any container (running or stopped)
#   kpod [-e]       kubectl logs on a pod; -e for exec instead
#   awsprofile      pick AWS_PROFILE from ~/.aws/config, verify with sts

# Internal: locate fd or fdfind.
_fzf_fd() {
    if command -v fd >/dev/null 2>&1; then command fd "$@"
    elif command -v fdfind >/dev/null 2>&1; then command fdfind "$@"
    else return 127
    fi
}

# fzcd — fuzzy directory picker with eza tree preview, then cd.
fzcd() {
    local target
    target=$(_fzf_fd --type d --hidden --exclude .git . 2>/dev/null \
        | fzf --preview 'eza --tree --level=2 --color=always --icons {} 2>/dev/null || ls -la {}') \
        || return
    [ -n "$target" ] && cd -- "$target"
}

# fzrg — ripgrep + fzf with line-context preview, then open in $EDITOR.
fzrg() {
  local search_term="$1"
  if [ -z "$search_term" ]; then
    echo "Usage: fzrg <search_term>"
    return 1
  fi

  local rg_flags=(--color=always --line-number --no-heading)
    # Smart-case: case-insensitive when the term has no uppercase.
  [[ "$search_term" =~ [A-Z] ]] || rg_flags+=(--ignore-case)

  local selected
    selected=$(command rg "${rg_flags[@]}" "$search_term" 2>/dev/null \
        | fzf --ansi --delimiter=: \
              --preview 'l={2}; bat --style=numbers --color=always \
                  --highlight-line "$l" \
                  --line-range "$((l-5>0?l-5:1)):$((l+15))" {1} 2>/dev/null' \
              --preview-window='right:55%:wrap')

    [ -z "$selected" ] && return 0

    local file line
    file=$(awk -F: '{print $1; exit}' <<<"$selected")
    line=$(awk -F: '{print $2; exit}' <<<"$selected")
    if [[ "$line" =~ ^[0-9]+$ ]]; then
        "${EDITOR:-nvim}" +"$line" "$file"
    else
      echo "Could not extract a valid line number from: $selected"
    fi
}
