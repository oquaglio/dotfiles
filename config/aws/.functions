# Get AWS current account number (set by env vars AWS_DEFAULT_PROFILE or AWS_PROFILE
# 'command' prevents recursion by bypassing any function or alias with 'aws'
# E.g. run 'aws acc'
aws() {
    if [[ $# -eq 0 || $@ == "acc" ]]; then
        local identity
        identity=$(command aws sts get-caller-identity 2>&1) || { echo "Error: $identity"; return 1; }
        local account_id alias alias_str
        account_id=$(echo "$identity" | jq -r '.Account')
        alias=$(command aws iam list-account-aliases 2>/dev/null | jq -r '.AccountAliases[0] // empty')
        alias_str="${account_id}${alias:+ ($alias)}"
        echo "Account : $alias_str"
        echo "Arn     : $(echo "$identity" | jq -r '.Arn')"
        echo "UserId  : $(echo "$identity" | jq -r '.UserId')"
        echo "Region  : $(command aws configure get region 2>/dev/null || echo 'not set')"
        echo "Profile : ${AWS_PROFILE:-${AWS_DEFAULT_PROFILE:-default}}"
        local aws_vars
        aws_vars=$(env | grep "^AWS_" | sort)
        [[ -n "$aws_vars" ]] && echo "---" && echo "$aws_vars"
    else
        command aws "$@"
    fi
}

load_aws_profile() {
    local profile="${1:-personal}"
    export AWS_PROFILE="$profile"
    export AWS_ACCESS_KEY_ID=$(pass show aws/$profile/access-key-id)
    export AWS_SECRET_ACCESS_KEY=$(pass show aws/$profile/secret-access-key)
    export AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
    echo "✓ AWS profile loaded: $profile"
}

awskill() {
    # Clean environment variables
    unset AWS_PROFILE
    unset AWS_DEFAULT_PROFILE
    unset AWS_REGION
    unset AWS_DEFAULT_REGION
    unset AWS_CONFIG_FILE
    unset AWS_SHARED_CREDENTIALS_FILE
    unset AWS_ACCESS_KEY_ID
    unset AWS_SECRET_ACCESS_KEY
    unset AWS_SESSION_TOKEN
    unset AWS_ACCOUNT_ID   # if you use this custom var
    unset AWS_CREDENTIAL_EXPIRATION

    # Actually terminate the SSO session (most important part)
    # deletes tokens in ~
    # aws sso logout 2>/dev/null || true   # ignore if no session exists

    # echo "AWS SSO session terminated and environment variables cleared."
    echo "AWS environment variables cleared."
}

check_aws_session() {
    # Capture the output of the AWS identity information
    aws_identity_output=$(aws sts get-caller-identity 2>&1)

    # Check the exit status of the AWS CLI command
    if [ $? -eq 0 ]; then
        # Extract the Account ID from the JSON output using jq
        account_id=$(echo "$aws_identity_output" | jq -r '.Account')
        # Optionally, extract the user or role name
        user_arn=$(echo "$aws_identity_output" | jq -r '.Arn')

        echo "Valid AWS session found for Account ID: $account_id, ARN: $user_arn"
        return 0  # Success exit code
    else
        echo "No valid AWS session found. Error: $aws_identity_output"
        return 1  # Failure exit code
    fi
}

s3cat() {
    local temp_file=~/temp/temps3file

    if [[ -z "$1" ]]; then
        echo "Usage: s3cat s3://your-bucket/path/to/file"
        return 1
    fi

    # Copy the S3 file locally
    aws s3 cp "$1" "$temp_file" --quiet

    if [[ $? -ne 0 ]]; then
        echo "Error: Failed to download file from S3."
        return 1
    fi

    # Detect JSON and pretty-print with jq if available
    if [[ "$1" == *.json ]] && command -v jq &> /dev/null; then
        cat "$temp_file" | jq .
    else
        cat "$temp_file"
    fi

    # Remove temporary file
    rm -f "$temp_file"
}

# s3trigger — download an S3 object and re-upload it to the same key to fire a
# fresh s3:ObjectCreated event (handy for replaying a Lambda/SQS/EventBridge
# trigger without changing the object's contents).
#
#   s3trigger s3://bucket/path/to/key
#
# Content-Type and user metadata are read from the existing object (head-object)
# and passed back on upload, so the re-put doesn't degrade the object to
# octet-stream / strip metadata. NOT preserved: SSE/KMS key (falls back to the
# bucket default), storage class, ACL, tags. Large objects re-upload via
# multipart, so the event is ObjectCreated:CompleteMultipartUpload rather than
# :Put — fine if your notification filters on s3:ObjectCreated:*.
#
# (An in-place `aws s3 cp s3://k s3://k --metadata-directive REPLACE` would fire
# an ObjectCreated:Copy without downloading, but the ask here is a real re-put.)
s3trigger() {
    local uri="$1"
    if [[ -z "$uri" || "$uri" != s3://* ]]; then
        echo "Usage: s3trigger s3://bucket/path/to/key" >&2
        return 1
    fi

    # Split s3://bucket/key into bucket + key for head-object.
    local rest="${uri#s3://}"
    local bucket="${rest%%/*}"
    local key="${rest#*/}"
    if [[ "$bucket" == "$rest" || -z "$key" ]]; then
        echo "Error: could not parse bucket/key from '$uri'." >&2
        return 1
    fi

    # Read existing Content-Type + user metadata so the re-upload preserves them.
    local head
    head=$(command aws s3api head-object --bucket "$bucket" --key "$key" 2>&1) || {
        echo "Error: object not found or access denied: $uri" >&2
        echo "$head" >&2
        return 1
    }
    local content_type metadata
    content_type=$(echo "$head" | jq -r '.ContentType // empty')
    metadata=$(echo "$head" | jq -r 'if (.Metadata // {} | length) > 0 then (.Metadata | to_entries | map("\(.key)=\(.value)") | join(",")) else empty end')

    local tmp
    tmp=$(mktemp) || { echo "mktemp failed" >&2; return 1; }

    if ! command aws s3 cp "$uri" "$tmp" --quiet; then
        echo "Error: failed to download $uri" >&2
        rm -f "$tmp"; return 1
    fi

    # Re-upload (PutObject), re-applying the preserved attributes.
    local args=("$tmp" "$uri" --quiet)
    [[ -n "$content_type" ]] && args+=(--content-type "$content_type")
    [[ -n "$metadata" ]] && args+=(--metadata "$metadata")
    if ! command aws s3 cp "${args[@]}"; then
        echo "Error: failed to re-upload $uri" >&2
        rm -f "$tmp"; return 1
    fi

    rm -f "$tmp"
    echo "✓ Re-uploaded $uri — fresh s3:ObjectCreated event fired."
}

set_aws_vars() {

    if [ -n "$AWS_PROFILE" ]; then
        export AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text --profile "$AWS_PROFILE")
        export AWS_ACCESS_KEY_ID=$(aws configure get aws_access_key_id --profile "$AWS_PROFILE")
        export AWS_SECRET_ACCESS_KEY=$(aws configure get aws_secret_access_key --profile "$AWS_PROFILE")
        #export AWS_REGION='ap-southeast-2'
        export AWS_REGION=$(aws configure get region --profile "$AWS_PROFILE")
    fi

    #export TF_VAR_aws_account_id=$AWS_ACCOUNT_ID
    #export TF_VAR_aws_region=$AWS_REGION
    #export TF_VAR_aws_access_key=$AWS_ACCESS_KEY_ID
    #export TF_VAR_aws_secret_key=$AWS_SECRET_ACCESS_KEY
}

# awsprofile — fzf-pick AWS_PROFILE from ~/.aws/config; verify with sts.
# Companion to the existing `sa` alias and `awskill` reset function.
awsprofile() {
    local cfg="$HOME/.aws/config"
    if [ ! -f "$cfg" ]; then
        echo "No $cfg — run: aws configure (or aws configure sso)" >&2
        return 1
    fi
    local profile
    profile=$(awk '
        /^\[profile / { gsub(/[][]/,""); print $2 }
        /^\[default\]/ { print "default" }
    ' "$cfg" \
        | sort -u \
        | fzf --header='select AWS_PROFILE') \
        || return
    [ -z "$profile" ] && return
    export AWS_PROFILE="$profile"
    echo "AWS_PROFILE=$profile"
    command aws sts get-caller-identity --output table 2>/dev/null \
        || echo "(not authenticated — try: aws sso login)" >&2
}
