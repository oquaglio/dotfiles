# Python virtual-environment discovery and cleanup.
#
# Commands:
#   venvs [root]              list every venv under <root> (default $HOME), sorted by size desc
#   venvs_clean [-y] [root]   interactively delete venvs; -y / --yes skips prompts
#
# Detection: pyvenv.cfg, bin/activate, or Scripts/activate(.bat). Confirmed
# by a python interpreter at bin/python or Scripts/python.exe. Broken-symlink
# pythons are kept in the list — they're prime cleanup candidates.
#
# Classification covers: venv, virtualenv, uv, poetry, pdm, hatch, pipenv,
# pyenv-virtualenv, virtualenvwrapper, pipx, conda/mamba. Tagged (broken)
# when the python symlink is dangling.
#
# Cleanup safety: conda envs are skipped — `conda env remove -n <name>` is
# the right tool, since deleting the dir leaves conda's index inconsistent.
#
# Walk prunes node_modules and .git for speed; keeps .cache (poetry parks
# its venvs there).
#
# Note: every du/find/grep below uses `command` to bypass user aliases —
# e.g. `alias du='du -ch'` would otherwise inject a total line and break
# size parsing.

# Internal: emit one venv-root path per line from <root>.
_venvs_find() {
    local root="${1:-$HOME}"
    command find "$root" \
        -type d \( -name node_modules -o -name .git \) -prune -o \
        -type f \( \
            -name pyvenv.cfg -o \
            -path '*/bin/activate' -o \
            -path '*/Scripts/activate' -o \
            -path '*/Scripts/activate.bat' \
        \) -print 2>/dev/null \
    | awk '{
        sub(/\/[^\/]+$/, "");          # strip the matched filename
        sub(/\/(bin|Scripts)$/, "");   # if we matched an activate, strip bin/Scripts too
        print
    }' \
    | sort -u
}

# Internal: classify a venv directory. Echoes a short tag.
_venvs_classify() {
    local dir="$1"
    local kind="venv"

    if [ -d "$dir/conda-meta" ]; then
        echo "conda"
        return
    fi

    # Path-based tags (strongest signal).
    case "$dir" in
        */pipx/venvs/*)              kind="pipx" ;;
        */.virtualenvs/*)            kind="virtualenvwrapper" ;;
        */pyenv/versions/*/envs/*)   kind="pyenv-virtualenv" ;;
        */.cache/pypoetry/virtualenvs/*) kind="poetry" ;;
    esac

    # Content-based refinement.
    if [ -f "$dir/pyvenv.cfg" ]; then
        if command grep -q '^uv =' "$dir/pyvenv.cfg" 2>/dev/null; then
            kind="uv"
        elif command grep -q '^home =.*pyenv/versions' "$dir/pyvenv.cfg" 2>/dev/null; then
            kind="pyenv"
        fi
    fi

    # Project-local hints (parent directory).
    local parent
    parent=$(dirname "$dir")
    if [ -f "$parent/poetry.lock" ]; then
        kind="poetry"
    elif [ -f "$parent/pdm.lock" ]; then
        kind="pdm"
    elif [ -f "$parent/Pipfile" ]; then
        kind="pipenv"
    elif command grep -q '\[tool\.uv\]' "$parent/pyproject.toml" 2>/dev/null; then
        kind="uv"
    elif command grep -q '\[tool\.hatch' "$parent/pyproject.toml" 2>/dev/null; then
        kind="hatch"
    fi

    # Mark broken (dangling python symlink) — prime cleanup candidates.
    if [ -L "$dir/bin/python" ] && [ ! -e "$dir/bin/python" ]; then
        kind="$kind (broken)"
    fi

    echo "$kind"
}

# Internal: is this directory actually a venv? (has a python interpreter)
_venvs_is_venv() {
    local dir="$1"
    [ -x "$dir/bin/python" ] || \
    [ -f "$dir/bin/python" ] || \
    [ -f "$dir/Scripts/python.exe" ] || \
    { [ -L "$dir/bin/python" ] && return 0; }
}

# Internal: size of a directory in bytes (single line, alias-safe).
_venvs_bytes() {
    command du -sb "$1" 2>/dev/null | head -n1 | awk '{print $1}'
}

# Internal: human-friendly size; uses numfmt if available.
_venvs_human() {
    if command -v numfmt >/dev/null 2>&1; then
        numfmt --to=iec --suffix=B --padding=6 "$1"
    else
        # Fallback: fixed-width passthrough.
        printf '%6sB' "$1"
    fi
}

venvs() {
    local root="${1:-$HOME}"
    echo "Scanning $root for Python virtual environments (this may take a minute)..."

    local tmp
    tmp=$(mktemp) || { echo "mktemp failed" >&2; return 1; }

    _venvs_find "$root" | while IFS= read -r dir; do
        _venvs_is_venv "$dir" || continue
        local bytes kind human
        bytes=$(_venvs_bytes "$dir")
        [ -z "$bytes" ] && continue
        kind=$(_venvs_classify "$dir")
        human=$(_venvs_human "$bytes")
        # Tab-separated: bytes (for sorting), human size, kind, path.
        printf '%s\t%s\t%s\t%s\n' "$bytes" "$human" "$kind" "$dir" >> "$tmp"
    done

    if [ ! -s "$tmp" ]; then
        echo "No virtual environments found."
        rm -f "$tmp"
        return 0
    fi

    # Render: header + numeric-sorted rows, drop the byte column, align columns.
    {
        printf 'SIZE\tTYPE\tPATH\n'
        sort -t$'\t' -k1,1nr "$tmp" | cut -f2-
    } | column -t -s $'\t'

    # Footer: count and total.
    local count total total_h
    count=$(awk 'END{print NR}' "$tmp")
    total=$(awk -F'\t' '{s+=$1} END{print s+0}' "$tmp")
    total_h=$(_venvs_human "$total")
    printf '\n%d venvs, %s total\n' "$count" "$total_h"

    rm -f "$tmp"
}

venvs_clean() {
    local assume_yes=0
    case "$1" in
        -y|--yes) assume_yes=1; shift ;;
    esac
    local root="${1:-$HOME}"

    _venvs_find "$root" | while IFS= read -r dir; do
        _venvs_is_venv "$dir" || continue
        local bytes kind human
        bytes=$(_venvs_bytes "$dir")
        kind=$(_venvs_classify "$dir")
        human=$(_venvs_human "${bytes:-0}")

        # Refuse to delete conda envs — let conda own its tree.
        case "$kind" in
            conda)
                printf 'skip     %s  %-20s  %s\n' "$human" "$kind" "$dir"
                continue
                ;;
        esac

        if [ "$assume_yes" -eq 1 ]; then
            if rm -rf -- "$dir"; then
                printf 'removed  %s  %-20s  %s\n' "$human" "$kind" "$dir"
            else
                printf 'FAILED   %s  %-20s  %s\n' "$human" "$kind" "$dir"
            fi
        else
            printf 'Delete  %s  %-20s  %s ? [y/N] ' "$human" "$kind" "$dir"
            read -r reply
            case "$reply" in
                [yY]*) rm -rf -- "$dir" && echo '  → removed' ;;
                *)     echo '  → kept' ;;
            esac
        fi
    done
}
