# Git branch hygiene.
#
# Commands:
#   gitstale       list local branches whose upstream is gone or that are merged
#                  into the default branch (read-only — safe to run anywhere)
#   gitprune       same scan but interactively delete each branch (y/N prompt).
#                  Prints the SHA of every deleted branch so recovery is
#                  `git branch <name> <sha>`.
#
# Both run `git fetch --prune` first to ensure remote state is current.

# Internal: detect the default branch (origin/HEAD → main/master/whatever).
_git_default_branch() {
    local b
    b=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's@^refs/remotes/origin/@@')
    if [ -z "$b" ]; then
        # Fallback: pick whichever of main/master exists locally.
        if git show-ref --verify --quiet refs/heads/main; then
            b=main
        elif git show-ref --verify --quiet refs/heads/master; then
            b=master
        fi
    fi
    echo "$b"
}

# Internal: emit the list of stale-branch candidates, one per line, deduped.
_git_stale_candidates() {
    local default current
    default=$(_git_default_branch)
    current=$(git symbolic-ref --short HEAD 2>/dev/null)

    {
        # Branches whose tracked remote is gone.
        git branch -vv 2>/dev/null | awk '/: gone\]/ { print $1 }' | sed 's/^\*//'

        # Branches already merged into the default branch.
        if [ -n "$default" ]; then
            git branch --merged "$default" 2>/dev/null \
                | sed 's/^[* ]*//' \
                | grep -vE "^(${default}|main|master)$"
        fi
    } \
    | sort -u \
    | grep -vxF -- "$current" \
    || true
}

gitstale() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Not inside a git repo." >&2
        return 1
    fi

    local default
    default=$(_git_default_branch)
    : "${default:?Could not detect default branch}"

    echo "Fetching (with --prune)..."
    git fetch --prune --quiet

    echo
    echo "=== Local branches whose upstream is gone ==="
    git branch -vv | awk '/: gone\]/ { print "  " $0 }' || echo "  (none)"

    echo
    echo "=== Local branches merged into $default ==="
    local merged
    merged=$(git branch --merged "$default" 2>/dev/null \
        | sed 's/^[* ]*//' \
        | grep -vE "^(${default}|main|master)$" || true)
    if [ -z "$merged" ]; then
        echo "  (none)"
    else
        echo "$merged" | sed 's/^/  /'
    fi

    echo
    echo "(run \`gitprune\` to interactively delete)"
}

gitprune() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Not inside a git repo." >&2
        return 1
    fi

    git fetch --prune --quiet

    local candidates
    candidates=$(_git_stale_candidates)

    if [ -z "$candidates" ]; then
        echo "No stale branches."
        return 0
    fi

    echo "$candidates" | while IFS= read -r branch; do
        [ -z "$branch" ] && continue
        local sha
        sha=$(git rev-parse --short "$branch" 2>/dev/null) || continue
        printf 'Delete %s (%s)? [y/N] ' "$branch" "$sha"
        read -r reply
        case "$reply" in
            [yY]*)
                if git branch -D -- "$branch" >/dev/null 2>&1; then
                    printf '  → deleted (recover with: git branch %s %s)\n' "$branch" "$sha"
                else
                    echo '  → delete failed'
                fi
                ;;
            *)
                echo '  → kept'
                ;;
        esac
    done
}
